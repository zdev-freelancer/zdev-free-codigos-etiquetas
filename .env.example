# Supabase — copy to .env.local and fill in your project values.
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Server-only secret (Phase 5: server-side guest order creation). NEVER expose
# this to the client and NEVER commit it.
# SUPABASE_SERVICE_ROLE_KEY=

# Google Analytics 4 Measurement ID (optional). Leave empty to disable tracking.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Mercado Pago (Checkout Pro). Leave empty to use the demo confirmation flow.
# Mercado Pago → Tus integraciones → Credenciales.
MERCADOPAGO_ACCESS_TOKEN=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=
